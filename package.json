{
  "name": "@swopstar/react-ui",
  "version": "0.2606.3",
  "description": "Shared React component library for swop* projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/swopstar/react-ui"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "build-storybook": "storybook build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.511.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.11.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.2.9"
  },
  "devDependencies": {
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@tailwindcss/vite": "^4.1.7",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "@vitejs/plugin-react": "^4.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.4.4",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4"
  }
}
